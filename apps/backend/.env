# Server Deployment Configurations
PORT=5000
NODE_ENV=development

# Database Transmission Connection Strings
# Replace user, password, host, port, and dbname with your local PostgreSQL variables
DATABASE_URL="postgresql://postgres:secret_password@localhost:5432/pharmo_db?schema=public"

# Frontend Communications Access Origin Control
FRONTEND_URL="http://localhost:5173"

# Cryptographic Token Signatures Matrix Key
JWT_SECRET="pharmo-core-terminal-session-secret-key-signature-2026"