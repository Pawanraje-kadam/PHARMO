# Server Deployment Configurations
PORT=5000
NODE_ENV=development

# Database Transmission Connection Strings
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Frontend Communications Access Origin Control
FRONTEND_URL="http://localhost:5173"

# Cryptographic Token Signatures Matrix Key
JWT_SECRET="your-secret-key-here"

# GROQ AI API Key (for AI-powered medicine enrichment & safety analysis)
# Get your key at https://console.groq.com
GROQ_API_KEY="your-groq-api-key-here"
