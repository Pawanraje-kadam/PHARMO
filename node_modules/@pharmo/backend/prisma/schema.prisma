datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CASHIER
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  password_hash String
  role          Role     @default(CASHIER)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  sales         Sale[]

  @@map("users")
}

model Medicine {
  id              String             @id @default(uuid())
  name            String             @unique
  generic_name    String?
  manufacturer    String?
  rack_location   String?
  min_stock_level Int                @default(10)
  is_deleted      Boolean            @default(false)
  created_at      DateTime           @default(now())
  batches         Batch[]
  ai_knowledge    MedicineKnowledge?

  @@map("medicines")
}

model Batch {
  id            String     @id @default(uuid())
  medicine_id   String
  batch_number  String
  quantity      Int
  buying_price  Decimal    @db.Decimal(10, 2)
  selling_price Decimal    @db.Decimal(10, 2)
  expiry_date   DateTime
  created_at    DateTime   @default(now())
  medicine      Medicine   @relation(fields: [medicine_id], references: [id], onDelete: Cascade)
  sale_items    SaleItem[]

  @@unique([medicine_id, batch_number])
  @@map("batches")
}

model MedicineKnowledge {
  id                   String   @id @default(uuid())
  medicine_id          String   @unique
  generic_ingredient   String
  therapeutic_category String
  drug_class           String
  common_uses          String[]
  age_restrictions     String?
  adult_dosage         String
  pediatric_dosage     String?
  is_otc               Boolean  @default(true)
  contraindications    String[]
  common_side_effects  String[]
  pregnancy_warnings   String
  breastfeeding_warnings String
  food_instructions    String?
  storage_conditions   String?
  important_warnings   String
  search_keywords      String[]
  synonyms             String[]
  embedding_vector     Float[]  // Simulated embedding cache slice mapping
  enrichment_status    String   @default("PENDING") // PENDING, COMPLETED, FAILED
  retry_count          Int      @default(0)
  failure_log          String?
  updated_at           DateTime @updatedAt
  medicine             Medicine @relation(fields: [medicine_id], references: [id], onDelete: Cascade)

  @@map("medicine_knowledge")
}

model Sale {
  id           String     @id @default(uuid())
  user_id      String
  total_amount Decimal    @db.Decimal(10, 2)
  created_at   DateTime   @default(now())
  user         User       @relation(fields: [user_id], references: [id])
  items        SaleItem[]

  @@map("sales")
}

model SaleItem {
  id         String   @id @default(uuid())
  sale_id    String
  batch_id   String
  quantity   Int
  unit_price Decimal  @db.Decimal(10, 2)
  subtotal   Decimal  @db.Decimal(10, 2)
  sale       Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  batch      Batch    @relation(fields: [batch_id], references: [id])

  @@map("sale_items")
}